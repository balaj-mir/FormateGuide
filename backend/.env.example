# FormatGuard Backend Environment Variables
# Copy this file to .env and fill in your values

# Database (PostgreSQL via Supabase or local)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/formatguard

# Redis (Celery broker + session cache)
REDIS_URL=redis://localhost:6379/0

# Supabase Authentication
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# S3 / Cloudflare R2 Storage
AWS_ACCESS_KEY_ID=your-r2-or-s3-key
AWS_SECRET_ACCESS_KEY=your-r2-or-s3-secret
S3_BUCKET_NAME=formatguard-documents
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# OpenAI API
OPENAI_API_KEY=sk-...

# Sentry Error Monitoring (optional)
SENTRY_DSN=
