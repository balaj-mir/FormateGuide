{
  "id": "apa-7th-v1",
  "name": "APA 7th Edition",
  "description": "American Psychological Association 7th Edition formatting guidelines. Supports both Times New Roman 12pt and Calibri 11pt.",
  "version": "1.0",
  "institution": "APA",
  "is_public": true,
  "rules": {
    "page_setup": {
      "paper_size": "Letter",
      "orientation": "portrait",
      "margin_top_cm": 2.54,
      "margin_bottom_cm": 2.54,
      "margin_left_cm": 2.54,
      "margin_right_cm": 2.54,
      "severity": "critical",
      "enabled": true
    },
    "body_text": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "font_size_tolerance_pt": 0.5,
      "line_spacing": 2.0,
      "alignment": "left",
      "bold": false,
      "italic": false,
      "severity": "critical",
      "enabled": true
    },
    "heading_1": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "bold": true,
      "italic": false,
      "alignment": "center",
      "severity": "critical",
      "enabled": true
    },
    "heading_2": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "bold": true,
      "italic": false,
      "alignment": "left",
      "severity": "critical",
      "enabled": true
    },
    "heading_3": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "bold": true,
      "italic": true,
      "alignment": "left",
      "severity": "warning",
      "enabled": true
    },
    "page_numbers": {
      "position": "top_right",
      "format": "arabic",
      "start_page": 1,
      "severity": "warning",
      "enabled": true
    },
    "references": {
      "style": "APA",
      "required": true,
      "severity": "critical",
      "enabled": true
    },
    "table_of_contents": {
      "required": false,
      "severity": "suggestion",
      "enabled": true
    }
  }
}
