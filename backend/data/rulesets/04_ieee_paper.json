{
  "id": "ieee-paper-v1",
  "name": "IEEE Paper Format",
  "description": "IEEE conference and journal paper formatting standard. Two-column layout with 10pt body text.",
  "version": "1.0",
  "institution": "IEEE",
  "is_public": true,
  "rules": {
    "page_setup": {
      "paper_size": "Letter",
      "orientation": "portrait",
      "margin_top_cm": 2.54,
      "margin_bottom_cm": 2.54,
      "margin_left_cm": 1.75,
      "margin_right_cm": 1.75,
      "severity": "critical",
      "enabled": true
    },
    "body_text": {
      "font_family": "Times New Roman",
      "font_size_pt": 10,
      "font_size_tolerance_pt": 0.5,
      "line_spacing": 1.0,
      "alignment": "justified",
      "bold": false,
      "italic": false,
      "severity": "critical",
      "enabled": true
    },
    "heading_1": {
      "font_family": "Times New Roman",
      "font_size_pt": 10,
      "bold": true,
      "italic": false,
      "alignment": "center",
      "numbering_format": "{ROMAN}. ",
      "severity": "critical",
      "enabled": true
    },
    "heading_2": {
      "font_family": "Times New Roman",
      "font_size_pt": 10,
      "bold": false,
      "italic": true,
      "alignment": "left",
      "numbering_format": "{A}. ",
      "severity": "warning",
      "enabled": true
    },
    "page_numbers": {
      "position": "bottom_center",
      "format": "arabic",
      "start_page": 1,
      "severity": "warning",
      "enabled": true
    },
    "references": {
      "style": "IEEE",
      "required": true,
      "severity": "critical",
      "enabled": true
    }
  }
}
