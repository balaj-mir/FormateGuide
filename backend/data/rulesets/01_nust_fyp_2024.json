{
  "id": "nust-fyp-2024-v1",
  "name": "NUST FYP 2024 Guidelines",
  "description": "National University of Sciences & Technology (NUST) Final Year Project report formatting guidelines for 2024. Covers all formatting requirements for FYP/thesis reports.",
  "version": "1.0",
  "institution": "NUST",
  "is_public": true,
  "rules": {
    "page_setup": {
      "paper_size": "A4",
      "orientation": "portrait",
      "margin_top_cm": 2.54,
      "margin_bottom_cm": 2.54,
      "margin_left_cm": 3.81,
      "margin_right_cm": 2.54,
      "severity": "critical",
      "enabled": true
    },
    "body_text": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "font_size_tolerance_pt": 0.5,
      "line_spacing": 1.5,
      "alignment": "justified",
      "bold": false,
      "italic": false,
      "severity": "critical",
      "enabled": true
    },
    "heading_1": {
      "font_family": "Times New Roman",
      "font_size_pt": 14,
      "bold": true,
      "italic": false,
      "alignment": "center",
      "numbering_format": "Chapter {n}",
      "severity": "critical",
      "enabled": true
    },
    "heading_2": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "bold": true,
      "italic": false,
      "alignment": "left",
      "severity": "warning",
      "enabled": true
    },
    "heading_3": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "bold": true,
      "italic": true,
      "alignment": "left",
      "severity": "suggestion",
      "enabled": true
    },
    "page_numbers": {
      "position": "bottom_center",
      "format": "arabic",
      "start_page": 1,
      "severity": "warning",
      "enabled": true
    },
    "references": {
      "style": "IEEE",
      "required": true,
      "severity": "critical",
      "enabled": true
    },
    "table_of_contents": {
      "required": true,
      "severity": "critical",
      "enabled": true
    },
    "cover_page": {
      "required_fields": [
        "university_name",
        "department",
        "thesis_title",
        "student_name",
        "roll_number",
        "supervisor_name",
        "year"
      ],
      "severity": "critical",
      "enabled": true
    }
  }
}
