{
  "id": "comsats-fyp-v1",
  "name": "COMSATS University FYP",
  "description": "COMSATS University Islamabad Final Year Project formatting guidelines. Standard 1-inch margins with double spacing.",
  "version": "1.0",
  "institution": "COMSATS",
  "is_public": true,
  "rules": {
    "page_setup": {
      "paper_size": "A4",
      "orientation": "portrait",
      "margin_top_cm": 2.54,
      "margin_bottom_cm": 2.54,
      "margin_left_cm": 2.54,
      "margin_right_cm": 2.54,
      "severity": "critical",
      "enabled": true
    },
    "body_text": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "font_size_tolerance_pt": 0.5,
      "line_spacing": 2.0,
      "alignment": "justified",
      "bold": false,
      "italic": false,
      "severity": "critical",
      "enabled": true
    },
    "heading_1": {
      "font_family": "Arial",
      "font_size_pt": 14,
      "bold": true,
      "italic": false,
      "alignment": "left",
      "severity": "critical",
      "enabled": true
    },
    "heading_2": {
      "font_family": "Arial",
      "font_size_pt": 12,
      "bold": true,
      "italic": false,
      "alignment": "left",
      "severity": "warning",
      "enabled": true
    },
    "page_numbers": {
      "position": "bottom_right",
      "format": "arabic",
      "start_page": 1,
      "severity": "warning",
      "enabled": true
    },
    "references": {
      "style": "IEEE",
      "required": true,
      "severity": "critical",
      "enabled": true
    },
    "table_of_contents": {
      "required": true,
      "severity": "critical",
      "enabled": true
    },
    "cover_page": {
      "required_fields": [
        "university_name",
        "department",
        "thesis_title",
        "student_name",
        "registration_number",
        "supervisor_name",
        "year"
      ],
      "severity": "critical",
      "enabled": true
    }
  }
}
