{
  "id": "chicago-style-v1",
  "name": "Chicago Style",
  "description": "Chicago Manual of Style formatting guidelines with footnote/endnote or bibliography reference styles.",
  "version": "1.0",
  "institution": "Chicago",
  "is_public": true,
  "rules": {
    "page_setup": {
      "paper_size": "Letter",
      "orientation": "portrait",
      "margin_top_cm": 2.54,
      "margin_bottom_cm": 2.54,
      "margin_left_cm": 2.54,
      "margin_right_cm": 2.54,
      "severity": "critical",
      "enabled": true
    },
    "body_text": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "font_size_tolerance_pt": 0.5,
      "line_spacing": 2.0,
      "alignment": "left",
      "bold": false,
      "italic": false,
      "severity": "critical",
      "enabled": true
    },
    "heading_1": {
      "font_family": "Times New Roman",
      "font_size_pt": 14,
      "bold": true,
      "italic": false,
      "alignment": "center",
      "severity": "critical",
      "enabled": true
    },
    "heading_2": {
      "font_family": "Times New Roman",
      "font_size_pt": 12,
      "bold": true,
      "italic": false,
      "alignment": "left",
      "severity": "warning",
      "enabled": true
    },
    "page_numbers": {
      "position": "bottom_center",
      "format": "arabic",
      "start_page": 1,
      "severity": "warning",
      "enabled": true
    },
    "references": {
      "style": "Chicago",
      "required": true,
      "severity": "critical",
      "enabled": true
    }
  }
}
